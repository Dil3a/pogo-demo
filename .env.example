# ----------------------------------------------------------------------------
# POGO — Environment variables
# Copy to `.env.local` for local dev; never commit `.env.local`.
# ----------------------------------------------------------------------------

# Public — exposed to the browser. Treat as non-secret.
NEXT_PUBLIC_APP_NAME=POGO
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/mock
NEXT_PUBLIC_WS_URL=ws://localhost:3000/realtime

# Mock mode — when `true`, the frontend uses the in-process mock API and
# never reaches a real backend. Use `false` once you wire up NestJS.
NEXT_PUBLIC_USE_MOCK_API=true

# Map — MapLibre is free, but if you switch to a styled vector tile provider
# (Maptiler, Stadia) put the key here.
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAP_TILE_KEY=

# Campus center for initial map view (Université Euromed de Fès, Fes, Morocco).
NEXT_PUBLIC_CAMPUS_LAT=33.9716
NEXT_PUBLIC_CAMPUS_LNG=-5.0023
NEXT_PUBLIC_CAMPUS_ZOOM=16

# Server-only secrets — never prefixed with NEXT_PUBLIC_.
SESSION_SECRET=replace-with-random-32-byte-base64-string
QR_SIGNING_SECRET=replace-with-random-32-byte-base64-string

# Backend (when not using mock API)
API_URL=http://localhost:4000
# Used by the Next.js server when proxying to the real backend.
API_INTERNAL_URL=http://api:4000

# Payment provider — only used in real backend; documented here for completeness.
# CMI_MERCHANT_ID=
# CMI_STORE_KEY=
# CMI_GATEWAY_URL=

# Observability
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
