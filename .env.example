# ----------------------------------------------------------------------------
# POGO — Environment variables
# Copy to `.env.local` for local dev; never commit `.env.local`.
# ----------------------------------------------------------------------------

# Public — exposed to the browser. Treat as non-secret.
NEXT_PUBLIC_APP_NAME=POGO
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=/api/mock

# Fix 4: NEXT_PUBLIC_USE_MOCK_API included with default value
# Set to true to use the in-process mock API (no backend needed)
# Set to false once you wire up the real NestJS backend
NEXT_PUBLIC_USE_MOCK_API=true

# Fix 5: WebSocket URL from environment variable
# Development: ws://localhost:3000/realtime
# Production: wss://your-domain.com/realtime
NEXT_PUBLIC_WS_URL=ws://localhost:3000/realtime

# Campus center for initial map view (Université Euromed de Fès)
NEXT_PUBLIC_CAMPUS_LAT=34.04494255638137
NEXT_PUBLIC_CAMPUS_LNG=-5.064716632430015
NEXT_PUBLIC_CAMPUS_ZOOM=16

# Map style — MapLibre tile URL (no API key needed for OpenStreetMap)
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAP_TILE_KEY=

# Server-only secrets — never prefixed with NEXT_PUBLIC_
SESSION_SECRET=replace-with-random-32-byte-base64-string
QR_SIGNING_SECRET=replace-with-random-32-byte-base64-string

# Backend (when NEXT_PUBLIC_USE_MOCK_API=false)
API_URL=http://localhost:4000
API_INTERNAL_URL=http://api:4000

# Payment provider — CMI Maroc
# CMI_MERCHANT_ID=
# CMI_STORE_KEY=
# CMI_GATEWAY_URL=

# Observability
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
